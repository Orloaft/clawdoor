#!/usr/bin/env bash
# Remount the ext4 loop image after replugging the portable SSD.
# Requires sudo for the loop mount.
set -e
IMG="/media/orlovboros/NXT 256GB/ollama-models.ext4"
MNT="/mnt/ollama-ssd"
if mountpoint -q "$MNT"; then
  echo "Already mounted: $MNT"
  exit 0
fi
if [ ! -f "$IMG" ]; then
  echo "SSD image not found at: $IMG"
  echo "  Is the portable SSD plugged in and auto-mounted?"
  exit 1
fi
sudo mount -o loop "$IMG" "$MNT"
echo "Mounted: $IMG -> $MNT"
echo "Restart ollama so it sees the model:"
echo "  sudo systemctl restart ollama"
